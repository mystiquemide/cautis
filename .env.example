# Cautis — Environment Variables
# Copy to .env and fill in your keys

# AI Provider (required)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Casper Infrastructure (required)
# Get your token at https://cspr.cloud
CSPR_CLOUD_API_KEY=your-cspr-cloud-token

# Casper Testnet RPC (optional, uses public endpoint by default)
CASPER_TESTNET_RPC=https://rpc.testnet.casper.network
CASPER_TESTNET_EVENTS=https://events.testnet.casper.network

# x402 Facilitator (optional, uses CSPR.cloud by default)
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# Guardian Mode (optional)
# Set to "quick" for deterministic analysis without Claude API calls
# Leave unset for full Claude-powered guardian
GUARDIAN_MODE=quick
